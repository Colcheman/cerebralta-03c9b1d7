# ======================================================
# CEREBRALTA - Variáveis de Ambiente
# ======================================================
# Copie este arquivo para .env e preencha com suas credenciais.
#
# Para Cloudflare Pages: adicione estas variáveis em
# Settings → Environment Variables do seu projeto.
# ======================================================

# --- Supabase (Obrigatório) ---
# Crie um projeto em https://supabase.com/dashboard
# Vá em Settings → API para encontrar estas credenciais
VITE_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key-aqui"
VITE_SUPABASE_PROJECT_ID="seu-project-id"

# --- Google Gemini API (Para funcionalidade de IA) ---
# Obtenha gratuitamente em https://aistudio.google.com/app/apikey
# Tier gratuito: 15 req/min, 1M tokens/dia
GEMINI_API_KEY="sua-gemini-api-key"

# --- WhatsApp (Opcional - para notificações) ---
# URL do webhook do seu servidor Baileys/Evolution API
WHATSAPP_WEBHOOK_URL="https://seu-servidor.com/api/send-message"
